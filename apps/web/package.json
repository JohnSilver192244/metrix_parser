{
  "name": "@metrix-parser/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "XDG_CONFIG_HOME=.wrangler WRANGLER_HOME=.wrangler node ./scripts/vite-runner.mjs dev",
    "build": "XDG_CONFIG_HOME=.wrangler WRANGLER_HOME=.wrangler node ./scripts/vite-runner.mjs build",
    "preview": "XDG_CONFIG_HOME=.wrangler WRANGLER_HOME=.wrangler node ./scripts/vite-runner.mjs preview",
    "deploy": "npm run build && XDG_CONFIG_HOME=.wrangler WRANGLER_HOME=.wrangler wrangler deploy",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test ./src/**/*.test.ts ./src/**/*.test.tsx"
  },
  "dependencies": {
    "@metrix-parser/shared-types": "0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.2",
    "wrangler": "^4.82.2"
  }
}
