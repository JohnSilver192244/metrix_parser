{
  "name": "metrix-parser",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for the metrixParser MVP.",
  "packageManager": "pnpm@10.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @metrix-parser/web",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "check:workspace": "node scripts/verify-workspace.mjs",
    "deploy": "npm run deploy --workspace @metrix-parser/web",
    "deploy:web": "npm run deploy --workspace @metrix-parser/web",
    "deploy:cloudflare": "XDG_CONFIG_HOME=apps/web/.wrangler WRANGLER_HOME=apps/web/.wrangler wrangler --cwd=apps/web deploy",
    "monitor": "npm run monitor:omx",
    "monitor:omx": "node scripts/omx-dashboard.mjs",
    "dev:web": "npm run dev --workspace @metrix-parser/web",
    "generate:season-points-migration": "node scripts/generate-season-points-migration.mjs",
    "perf:capture": "node scripts/perf-capture.mjs",
    "perf:compare": "node scripts/perf-compare.mjs"
  },
  "dependencies": {
    "undici": "^5.29.0"
  }
}
